{
    "data": {
        "train_path": "data/dacon/train.csv",
        "test_path": "data/dacon/test.csv",
        "submission_path": "data/dacon/sample_submission.csv"
    },
    "feature_engineering": {
        "budget": {
            "iterations": 1,
            "time_limit_per_iteration": 1800
        },
        "profile": {
            "model": "gemini-2.5-flash",
            "temperature": 0.2,
            "max_tokens": 8192,
            "top_p": 0.9,
            "max_codegen_attempts": 2,
            "execution_timeout_sec": 120,
            "diagnose_focus_max_items": 3,
            "diagnose_text_max_chars": 220
        },
        "hypothesis": {
            "model": "gemini-2.5-flash",
            "temperature": 0.2,
            "max_tokens": 8192,
            "top_p": 0.9,
            "max_attempts": 2
        },
        "implement": {
            "model": "gemini-3-pro-preview",
            "temperature": 0.2,
            "max_tokens": 16344,
            "top_p": 0.9,
            "max_codegen_attempts": 2,
            "syntax_check": true,
            "enable_contract_check": true,
            "contract_sample_rows": 512,
            "max_contract_attempts": 2
        },
        "execute": {
            "validation_module": "src.val_wrapper",
            "validation_script": "src/val_wrapper.py",
            "timeout_sec": 1800,
            "syntax_check_generated_modules": true,
            "max_implement_fallbacks": 1,
            "predict_test": false,
            "enabled_blocks": null,
            "cv_type": null,
            "n_splits": null,
            "model_type": null,
            "metric": null
        },
        "diagnose": {
            "max_log_tail_chars": 4000,
            "std_warning_threshold": 0.02,
            "feature_count_warning_threshold": 700
        },
        "report": {
            "output_dir": "",
            "report_filename": "report.html",
            "report_json_filename": "report.json"
        }
    },
    "submission": {
        "run_id": null,
        "iteration": 1,
        "model_path": null,
        "preprocessor_path": null,
        "feature_engineering_path": null,
        "feature_generator_path": null,
        "enabled_blocks": null,
        "sanitize_feature_names": true,
        "allow_overwrite_output": true,
        "data": {
            "train_path": "data/dacon/train.csv",
            "test_path": "data/dacon/test.csv",
            "sample_submission_path": "data/dacon/sample_submission.csv",
            "output_path": "submissions/dacon/submission.csv",
            "id_col": "ID",
            "label_col": "completed"
        },
        "model": {
            "eval_metric": "f1",
            "problem_type": "binary",
            "presets": "best_quality",
            "time_limit": 1800,
            "num_gpus": 0
        },
        "validation": {
            "holdout_frac": 0.2,
            "random_state": 42
        },
        "fit": {
            "hyperparameters": "default",
            "fit_strategy": "sequential"
        }
    },
    "modeling": {
        "task_type": "regression",
        "metric": "rmse",
        "validation": {
            "cv_type": "auto",
            "n_splits": 5,
            "shuffle": true,
            "random_state": 42
        },
        "model": {
            "type": "lightgbm",
            "params": {}
        }
    }
}
