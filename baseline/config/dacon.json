    "eval_metric": "f1",
    "problem_type": "binary",
    "presets": "best_quality",
    "time_limit": 1800,
    "num_gpus": 0
  },
  "validation": {
    "holdout_frac": 0.2,
    "random_state": 42
  },
  "fit": {
    "hyperparameters": "default",
    "fit_strategy": "sequential"
  }
}
