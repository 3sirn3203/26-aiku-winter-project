{
  "data": {
    "train_path": "data/kaggle/train.csv",
    "test_path": "data/kaggle/test.csv",
    "sample_submission_path": "data/kaggle/sample_submission.csv",
    "output_path": "baseline/generated/submission_kaggle.csv",
    "id_col": "id",
    "label_col": "price"
  },
  "model": {
    "eval_metric": "rmse",
    "problem_type": "regression",
    "presets": "best_quality",
    "time_limit": 1800
  },
  "validation": {
    "method": "holdout",
    "holdout_frac": 0.2,
    "num_bag_folds": 5,
    "num_bag_sets": 1,
    "num_stack_levels": 0
  },
  "fit": {
    "hyperparameters": "default"
  }
}
