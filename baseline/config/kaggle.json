{
  "data": {
    "train_path": "data/kaggle/train.csv",
    "test_path": "data/kaggle/test.csv",
    "sample_submission_path": "data/kaggle/sample_submission.csv",
    "output_path": "baseline/generated/kaggle_ver1",
    "id_col": "id",
    "label_col": "price"
  },
  "model": {
    "eval_metric": "rmse",
    "problem_type": "regression",
    "presets": "best_quality",
    "time_limit": 1800,
    "num_gpus": 2
  },
  "validation": {
    "holdout_frac": 0.2,
    "random_state": 42
  },
  "fit": {
    "hyperparameters": "default",
    "fit_strategy": "sequential"
  }
}
